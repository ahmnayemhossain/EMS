# Server runtime
PORT=4000
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"

# Seed behavior
# Schema is managed by Prisma migrations. Run `npm run db:setup` (or the
# explicit Prisma migrate/seed commands) before starting the API.
SEED_DEFAULTS=true

# Reports
REPORT_QUERY_TIMEOUT_MS=8000

# File storage
# Keep uploads outside the app/release folder in production.
# Example Windows: UPLOADS_DIR=C:\\ems-data\\uploads
# Example Linux: UPLOADS_DIR=/var/ems/uploads
UPLOADS_DIR=
CDN_PUBLIC_BASE=/cdn
