# Server runtime
PORT=4000
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres

# Schema/seed behavior
# In production, prefer running migrations explicitly and set these to false.
AUTO_MIGRATE=true
SEED_DEFAULTS=true

# Reports
REPORT_QUERY_TIMEOUT_MS=8000

