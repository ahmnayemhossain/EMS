  description                                               String?
  is_default                                                Int                                    @default(0) @db.SmallInt
  is_active                                                 Int                                    @default(1) @db.SmallInt
  created_by_user_id                                        BigInt?
  updated_by_user_id                                        BigInt?
  created_at                                                DateTime                               @default(now()) @db.Timestamptz(6)
  updated_at                                                DateTime                               @default(now()) @db.Timestamptz(6)
  approval_hierarchy_group_steps                            approval_hierarchy_group_steps[]
  approval_hierarchy_group_transitions                      approval_hierarchy_group_transitions[]
  users_approval_hierarchy_groups_created_by_user_idTousers users?                                 @relation("approval_hierarchy_groups_created_by_user_idTousers", fields: [created_by_user_id], references: [id])
  users_approval_hierarchy_groups_updated_by_user_idTousers users?                                 @relation("approval_hierarchy_groups_updated_by_user_idTousers", fields: [updated_by_user_id], references: [id])
  approval_hierarchy_role_transitions                       approval_hierarchy_role_transitions[]
  approval_hierarchy_user_transitions                       approval_hierarchy_user_transitions[]

  @@index([module_key, is_default, is_active], map: "idx_approval_hierarchy_groups_module")
}

model approval_hierarchy_role_transitions {
  group_key                      String
  role_id                        BigInt
