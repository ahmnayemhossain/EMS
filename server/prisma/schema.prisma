generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model approval_hierarchy_group_steps {
  group_key                 String
  step_key                  String
  position_index            Int                       @default(0)
  created_at                DateTime                  @default(now()) @db.Timestamptz(6)
  approval_hierarchy_groups approval_hierarchy_groups @relation(fields: [group_key], references: [key], onDelete: Cascade)
  approval_hierarchy_steps  approval_hierarchy_steps  @relation(fields: [step_key], references: [key], onDelete: Cascade)

  @@id([group_key, step_key])
  @@index([group_key, position_index], map: "idx_approval_hierarchy_group_steps_group")
}

model approval_hierarchy_group_transitions {
  group_key                      String
  transition_key                 String
  position_index                 Int                            @default(0)
  created_at                     DateTime                       @default(now()) @db.Timestamptz(6)
  approval_hierarchy_groups      approval_hierarchy_groups      @relation(fields: [group_key], references: [key], onDelete: Cascade)
  approval_hierarchy_transitions approval_hierarchy_transitions @relation(fields: [transition_key], references: [key], onDelete: Cascade)

  @@id([group_key, transition_key])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model approval_hierarchy_groups {
  key                                                       String                                 @id
  name                                                      String
